root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = tab
indent_size = 3
tab_width = 3

[*.sh]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
