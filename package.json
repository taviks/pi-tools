{
  "name": "pi-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Custom Pi package and companion packages, user config templates, prompts, skills, and eval fixtures.",
  "license": "MIT",
  "keywords": [
    "pi-package"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check:layout": "bash scripts/check-layout.sh",
    "pi:link-config": "bash scripts/link-agent-config.sh --apply"
  },
  "pi": {
    "extensions": [
      "./src/extensions/box-editor.ts",
      "./src/extensions/notify.ts",
      "./src/extensions/theme-hotkey.ts",
      "./src/extensions/fast-mode.ts",
      "./src/extensions/btw.ts",
      "./src/extensions/cost-audit.ts",
      "./src/extensions/copy-last-as-md.ts",
      "./src/extensions/verify-command.ts",
      "./src/extensions/guard.ts",
      "./src/extensions/session-plan/index.ts",
      "./src/extensions/goal-loop.ts",
      "./src/extensions/subagent/index.ts",
      "./src/extensions/workflow/index.ts",
      "./src/extensions/workspace-id-guard.ts",
      "./src/extensions/bash-orphan-cleanup.ts",
      "./src/extensions/bash-output-compression.ts",
      "./src/extensions/autoresearch-project-toggle.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
